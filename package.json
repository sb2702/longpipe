{
  "name": "longpipe",
  "version": "0.1.0",
  "description": "Open-source WebGPU/WebGL2 video effects SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitest/browser": "^3.0.0",
    "@types/node": "^22.0.0",
    "playwright": "^1.44.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
