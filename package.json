{
  "name": "longpipe",
  "version": "0.0.12",
  "description": "Open-source WebGPU/WebGL2 video effects SDK — virtual backgrounds, background blur, portrait matting in real time in the browser.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "Sam Bhattacharyya",
  "homepage": "https://longpipe.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/sb2702/longpipe.git"
  },
  "bugs": {
    "url": "https://github.com/sb2702/longpipe/issues"
  },
  "keywords": [
    "webgpu",
    "webgl",
    "virtual-background",
    "background-blur",
    "background-removal",
    "portrait-matting",
    "video-effects",
    "webrtc",
    "real-time",
    "ml"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite --config demo/vite.config.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/browser": "^3.0.0",
    "@webgpu/types": "^0.1.69",
    "playwright": "^1.44.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
